{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TCOAAL Mod Installer",
  "version": "0.1.0",
  "identifier": "app.tcoaal.modinstaller",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TCOAAL Mod Installer",
        "width": 820,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../*.js": "tools",
      "../../../*.json": "tools",
      "../../../playerbundle/*": "tools/playerbundle",
      "../../../../app/js/libs/*": "app/js/libs",
      "runtime": "runtime"
    }
  },
  "plugins": {}
}
